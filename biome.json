{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noArrayIndexKey": "off"
      }
    }
  },
  "files": {
    "includes": [
      "index.html",
      "package.json",
      "tsconfig.json",
      "vite.config.ts",
      "src/**",
      "public/**",
      "!src/data/othello_openings.json"
    ]
  }
}
