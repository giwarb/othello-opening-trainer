{
  "name": "othello-opening-trainer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write index.html package.json tsconfig.json vite.config.ts src public",
    "lint": "biome check index.html package.json tsconfig.json vite.config.ts src public"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.3.0",
    "playwright": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
